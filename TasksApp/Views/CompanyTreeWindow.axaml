<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="400" Height="300"
        MinWidth="400" MinHeight="350"
        x:Class="TasksApp.Views.CompanyTreeWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="CompanyTreeWindow">

    <ScrollViewer>
        <StackPanel Spacing="5" Margin="10">
            <ItemsControl ItemsSource="{Binding Roles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" FontWeight="Bold" />
                            <TextBlock Text="↓" HorizontalAlignment="Center" IsVisible="{Binding IsLast, Converter={x:Static BoolConverters.Not}}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Window>