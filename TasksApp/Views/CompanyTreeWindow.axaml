<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TasksApp.ViewModels"
        Width="400" Height="300"
        MinWidth="400" MinHeight="350"
        x:Class="TasksApp.Views.CompanyTreeWindow"
        x:DataType="vm:CompanyTreeWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="CompanyTreeWindow">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:CompanyTreeWindowViewModel />
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="5" Margin="10">
            <ItemsControl ItemsSource="{Binding Roles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" FontWeight="Bold" />
                            <TextBlock Text="↓" HorizontalAlignment="Center" IsVisible="{Binding IsLast, Converter={x:Static BoolConverters.Not}}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Window>